{
  "name": "@sparkly/backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend server for Twinkly device control",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch src --ext ts,js,json --exec tsx src/server.ts",
    "start": "tsx src/server.ts",
    "start:production": "node dist/server-node.js"
  },
  "dependencies": {
    "@loglayer/transport-pino": "^2.2.17",
    "@ts-rest/core": "^3.52.1",
    "@sparkly/common": "file:../common",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "loglayer": "^8.4.0",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "simplex-noise": "^4.0.3",
    "smol-toml": "^1.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "nodemon": "^3.1.9",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
