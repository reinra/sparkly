{
  "name": "twinkly-ts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Twinkly LED controller with separate backend, frontend, and common modules",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:common && npm run build:backend && npm run build:frontend",
    "build:common": "npm run build --workspace=@twinkly-ts/common",
    "build:backend": "npm run build --workspace=@twinkly-ts/backend",
    "build:frontend": "npm run build --workspace=@twinkly-ts/frontend",
    "dev:backend": "npm run dev --workspace=@twinkly-ts/backend",
    "dev:frontend": "npm run dev --workspace=@twinkly-ts/frontend",
    "start:backend": "npm run start --workspace=@twinkly-ts/backend",
    "start:frontend": "npm run preview --workspace=@twinkly-ts/frontend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
