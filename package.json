{
  "name": "twinkly-ts",
  "version": "1.0.0",
  "type": "module",
  "description": "A simple Node.js TypeScript hello world project",
  "main": "dist/index.js",
  "scripts": {
    "build": "svelte-kit sync && tsc && vite build",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "start:server": "tsx src/backend/server.ts",
    "start:frontend": "vite dev",
    "dev:server": "nodemon --watch src --ext ts,js,json --exec tsx src/backend/server.ts",
    "dev:frontend": "vite dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/kit": "^2.49.2",
    "@types/node": "^20.10.0",
    "nodemon": "^3.1.9",
    "svelte": "^5.46.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "@ts-rest/core": "^3.52.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "smol-toml": "^1.6.0",
    "zod": "^3.25.76"
  }
}
