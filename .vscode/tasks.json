{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build All",
			"type": "shell",
			"command": "npm run build",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "Build Common",
			"type": "shell",
			"command": "npm run build:common",
			"group": "build",
			"problemMatcher": ["$tsc"]
		},
		{
			"label": "Build Backend",
			"type": "shell",
			"command": "npm run build:backend",
			"group": "build",
			"problemMatcher": ["$tsc"]
		},
		{
			"label": "Build Frontend",
			"type": "shell",
			"command": "npm run build:frontend",
			"group": "build",
			"problemMatcher": ["$tsc"]
		},
		{
			"label": "Dev: Backend",
			"type": "shell",
			"command": "npm run dev:backend",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Dev: Frontend",
			"type": "shell",
			"command": "npm run dev:frontend",
			"isBackground": true,
			"problemMatcher": []
		}
	]
}